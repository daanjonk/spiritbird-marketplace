{
  "name": "dataforseo",
  "version": "1.0.0",
  "description": "DataForSEO MCP server — real-time keyword research, SERP data, backlinks, on-page analysis, and more.",
  "author": {
    "name": "Daan Jonkman — SpiritBird"
  },
  "mcpServers": {
    "dataforseo": {
      "command": "npx",
      "args": ["-y", "dataforseo-mcp-server"],
      "env": {
        "DATAFORSEO_USERNAME": "${DATAFORSEO_USERNAME}",
        "DATAFORSEO_PASSWORD": "${DATAFORSEO_PASSWORD}"
      }
    }
  }
}
