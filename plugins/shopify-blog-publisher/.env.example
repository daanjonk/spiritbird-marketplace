# ===========================================
# Shopify Blog Publisher — Environment Config
# ===========================================
# Copy this file to .env and fill in your values.
# Then export them in your shell or use a .env loader.

# --- Shopify ---
# Your store's myshopify.com domain
SHOPIFY_STORE="your-store.myshopify.com"

# Blog ID to publish articles to (find in Shopify admin URL)
SHOPIFY_BLOG_ID="123456789"

# Custom App credentials (Settings → Apps → Develop apps)
SHOPIFY_CLIENT_ID="your-client-id"
SHOPIFY_CLIENT_SECRET="your-client-secret"

# Optional: API version (default: 2025-01)
# SHOPIFY_API_VERSION="2025-01"

# --- DataForSEO ---
# Option A: Login + password (recommended)
DATAFORSEO_LOGIN="your@email.com"
DATAFORSEO_PASSWORD="your-api-password"

# Option B: Pre-encoded Base64 token (alternative to login+password)
# DATAFORSEO_AUTH_TOKEN="base64-encoded-login:password"
